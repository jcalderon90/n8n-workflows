              "id": "29bc8a2a-9b6e-4b09-ae6d-30b74ab45b94",
              "name": "body",
              "value": "=<?xml version=\"1.0\" encoding=\"utf-8\"?>\n<soap:Envelope xmlns:soap=\"http://schemas.xmlsoap.org/soap/envelope/\">\n  <soap:Body>\n    <CreacionClientePotencialBot xmlns=\"http://tempuri.org/\">\n      <_OrigenCliente>100000001</_OrigenCliente>\n      <_Proyecto>\n        {{ \n        ($('SET CONTEXT').item.json.proyecto == 'pvv' ? 'PVV' : \n         $('SET CONTEXT').item.json.proyecto == 'pm' ? 'PMAR' : \n         $('SET CONTEXT').item.json.proyecto == 'pp' ? 'PPO' : \n         $('SET CONTEXT').item.json.proyecto) \n        }}\n      </_Proyecto>\n      <_Comentarios>Lead generado desde chatbot</_Comentarios>\n      <_UTMSource>{{ $('SET CONTEXT').item.json.canal.toLowerCase() == 'whatsapp' ? 100000004 : $('SET CONTEXT').item.json.canal.toLowerCase() == 'instagram' ? 100000012 : 100000005 }}</_UTMSource>\n      <_UTMCampaing>Cliente atendido desde Chatbot</_UTMCampaing>\n      <_Nombre>{{ $json.nombre.split(\" \")[0] }}</_Nombre>\n      <_Apellido>{{ $json.nombre.split(\" \")[1] || \"N/A\" }}</_Apellido>\n      <_TelefonoMovil>{{ $json.telefono }}</_TelefonoMovil>\n      <_CorreEletronico>{{ $json.correo }}</_CorreEletronico>\n      <_MetodocontactoPref>5</_MetodocontactoPref>\n    </CreacionClientePotencialBot>\n  </soap:Body>\n</soap:Envelope>",
              "type": "string"
            }
          ]
        },
