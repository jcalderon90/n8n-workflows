    },
    {
      "parameters": {
        "text": "=Lead Agent:\n{{ Array.isArray($('Messages').item.json.lead_messages) ? $('Messages').item.json.lead_messages.map(m => m.role + ': ' + m.content).join('\\n') : $('Messages').item.json.lead_messages }}\n\nRSVP Agent:\n{{ Array.isArray($('Messages').item.json.rsvp_messages) ? $('Messages').item.json.rsvp_messages.map(m => m.role + ': ' + m.content).join('\\n') : $('Messages').item.json.rsvp_messages }}\n\nPrincipal Agent:\n{{ Array.isArray($('Messages').item.json.principal_messages) ? $('Messages').item.json.principal_messages.map(m => m.role + ': ' + m.content).join('\\n') : $('Messages').item.json.principal_messages }}",
        "attributes": {
          "attributes": [
            {
              "name": "funnel_stage",
              "description": "=Etapa del funnel: 'nuevo' (solo saludÃ³), 'identificado' (dio datos), 'proyecto_activo' (eligiÃ³ proyecto), 'consultando' (hizo preguntas), 'en_rsvp' (iniciÃ³ agendamiento), 'cita_confirmada' (confirmÃ³ cita), 'escalado' (pidiÃ³ humano)",
              "required": true
            },
            {
              "name": "intencion_detectada",
              "description": "=En una frase corta, quÃ© buscaba el usuario en esta conversaciÃ³n",
              "required": true
            },
            {
              "name": "tools_correctas",
              "description": "=Â¿El agente usÃ³ las tools correctas en el momento correcto? Describe brevemente si lead_collector, kb_search, rsvp y send_media se usaron apropiadamente. Si no se usÃ³ alguna tool necesaria, indÃ­calo.",
              "required": true
            },
            {
              "name": "errores_detectados",
              "description": "=Lista numerada de errores en la lÃ³gica del agente: respuestas incorrectas, loops, confusiÃ³n de contexto, preguntas innecesarias. Escribe 'Ninguno' si no hay errores.",
              "required": true
            },
            {
              "name": "oportunidades_perdidas",
              "description": "=Momentos donde el agente pudo avanzar en el funnel o mejorar la experiencia pero no lo hizo. Escribe 'Ninguna' si no aplica.",
              "required": true
            },
