    {
      "parameters": {
        "text": "=DATOS ACTUALES EN SISTEMA:\n- Proyecto: {{ $('Loop Over Users').item.json.proyecto }}\n- Habitaciones: {{ $('Find Appointment').item.json.habitaciones || 'No especificado' }}\n- IntenciÃ³n: {{ $('Find Appointment').item.json.intencion || 'No especificada' }}\n- Cita: {{ $('Find Appointment').item.json.fecha_hora ? 'Agendada para ' + $('Find Appointment').item.json.fecha_hora : 'No agendada' }}\n\nHISTORIAL DE CONVERSACIÃ“N COMPLETO:\n\nHistorial del lead agent:{{ Array.isArray($json.lead_messages) ? $json.lead_messages.map(m => m.role + ': ' + m.content).join('\\\\n') : $json.lead_messages }} \n\nHistorial del rsvp agent: \n{{ Array.isArray($json.rsvp_messages) ? $json.rsvp_messages.map(m => m.role + ': ' + m.content).join('\\\\n') : $json.rsvp_messages }}\n\nHistorial del principal agent: \n{{ Array.isArray($json.principal_messages) ? $json.principal_messages.map(m => m.role + ': ' + m.content).join('\\\\n') : $json.principal_messages }}",
        "attributes": {
          "attributes": [
            {
              "name": "Presupuesto",
              "description": "Presupuesto mencionado por el cliente (ej: 'Q800,000', 'No mencionado').",
              "required": true
            },
            {
              "name": "Dormitorios",
              "description": "NÃºmero de habitaciones o tipo de unidad que busca.",
              "required": true
            },
            {
              "name": "Requisitos",
              "description": "Requisitos especÃ­ficos o amenidades de interÃ©s (ej: 'piso alto', 'con balcÃ³n', 'cerca de amenidades').",
              "required": true
            },
            {
              "name": "Resumen",
              "description": "Resumen narrativo de la conversaciÃ³n, quÃ© informaciÃ³n se le dio y en quÃ© punto quedÃ³.",
              "required": true
            },
            {
              "name": "Dudas",
              "description": "Lista numerada de todas las preguntas o dudas que expresÃ³ el cliente durante la conversaciÃ³n. Si no hay dudas explÃ­citas, escribe 'Ninguna'. Formato: 1. ... 2. ... 3. ...",
              "required": true
            }
          ]
        },
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.informationExtractor",
      "typeVersion": 1.2,
      "position": [
        4016,
        448
      ],
      "id": "6939e57a-adb2-4d63-8db2-1fa4f6301336",
